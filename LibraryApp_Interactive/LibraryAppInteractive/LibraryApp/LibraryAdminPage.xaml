<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryAdminPage"
             Title="Manage Book Assets">
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, Auto, *"
          Margin="20,0"
          RowSpacing="10">

            <!-- Form Section -->
            <VerticalStackLayout Spacing="10">

                <Label Text="New Book" FontSize="24"
                   Margin="0,20,0,0"/>

                <Label Text="Book Name:" FontSize="14"/>
                <Entry x:Name="_txtBookName"
                   Placeholder="Enter the book name" FontSize="17"/>

                <Label Text="ISBN:" FontSize="14"/>
                <Entry x:Name="_txtISBN"
                   Placeholder="Enter the ISBN" FontSize="17"/>

                <Label Text="Book Type:" FontSize="14"/>
                <Picker x:Name="_pckBookType"
                    Title="{OnPlatform MacCatalyst='', Default='Select the book type'}">
                    <Picker.Items>
                        <x:String>Paper</x:String>
                        <x:String>Digital</x:String>
                        <x:String>Audio</x:String>
                    </Picker.Items>
                </Picker>

                <Label Text="Author:" FontSize="14"/>
                <Entry x:Name="_txtAuthor"
                   Placeholder="Enter the author name" FontSize="17"/>

                <Label Text="Number of Copies:" FontSize="14"/>
                <Entry x:Name="_txtCopies"
                   Placeholder="Enter number of copies"
                   Keyboard="Numeric" FontSize="17"/>

                <Grid ColumnDefinitions="*, Auto"
                  Margin="0,10"
                  ColumnSpacing="10">
                    <Button Text="Register Book"
                        Grid.Column="0" WidthRequest="250"
                        HorizontalOptions="Start"
                        Clicked="OnRegisterBook"/>
                    <Button Text="Clear"
                        WidthRequest="100"
                        Grid.Column="1"
                        Clicked="OnClear"/>
                </Grid>

            </VerticalStackLayout>

            <!-- List Header -->
            <Label Text="Book Inventory" FontSize="24"
               Grid.Row="1"/>

            <!-- Book List -->
            <Border Grid.Row="2"
                Margin="{OnPlatform Default='0,0,0,80',
                                    iOS='0,0,0,30',
                                    Android='0,0,0,10'}">
                <CollectionView x:Name="_lstBookInventory"
                            HorizontalOptions="Fill"/>
            </Border>

        </Grid>

    </ContentPage.Content>
</ContentPage>